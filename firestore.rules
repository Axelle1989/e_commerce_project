rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // MODE DÉVELOPPEMENT OUVERT : Permet à n'importe qui de lire et d'écrire sur toute la base.
    // À restreindre impérativement avant la mise en production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
