# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# STRIPE_SECRET_KEY: Required for Stripe payments.
STRIPE_SECRET_KEY="sk_test_..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Admin configuration
VITE_FIREBASE_PROJECT_ID="ai-studio-applet-webapp-42c27"
VITE_FIREBASE_STORAGE_BUCKET="ai-studio-applet-webapp-42c27.firebasestorage.app"

# Google Maps API Key for Geocoding
VITE_GOOGLE_MAPS_API_KEY=""

# TWILIO (SMS Benin)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# BREVO (Email)
BREVO_API_KEY=""
EMAIL_FROM="votre@email.com"
