{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information including role and validation status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "driver", "admin"] },
        "status": { "type": "string", "enum": ["pending_email_verification", "pending_validation", "active", "suspended", "pending_interview"] },
        "verificationCode": { "type": "string" },
        "emailVerified": { "type": "boolean" },
        "phoneVerified": { "type": "boolean" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "photoURL": { "type": "string" },
        "idCardPhotoUrl": { "type": "string" },
        "rejectionReason": { "type": "string" },
        "currentLocation": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "noteMoyenne": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "validatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A delivery order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" },
              "proposedPricePerUnit": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "subTotal": { "type": "number" },
        "totalAmount": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "status": { "type": "string", "enum": ["awaiting_payment", "pending", "accepted", "at_market", "delivering", "delivered", "cancelled"] },
        "userLocation": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "driverLocation": { "type": "object", "description": "Current driver location" },
        "marketReachedLocation": { "type": "object", "description": "Location when driver reached market" },
        "marketReachedAt": { "type": "string", "format": "date-time" },
        "departureLocation": { "type": "object", "description": "Location when driver left market" },
        "departureAt": { "type": "string", "format": "date-time" },
        "deliveredLocation": { "type": "object", "description": "Location when order was delivered" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "proofPhotos": { "type": "array", "items": { "type": "string" } },
        "proofStatus": { "type": "string", "enum": ["pending", "submitted", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Rating and comment for a delivery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "driverId": { "type": "string" },
        "userId": { "type": "string" },
        "note": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "driverId", "userId", "note"]
    },
    "AdminNotification": {
      "title": "AdminNotification",
      "description": "Notifications for the admin dashboard.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["new_driver_request", "order_alert"] },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "read", "createdAt"]
    },
    "AdminLog": {
      "title": "AdminLog",
      "description": "Logs of administrative actions.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "targetUserEmail": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "timestamp"]
    },
    "AdminReport": {
      "title": "AdminReport",
      "description": "Monthly performance reports with AI advice.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "month": { "type": "string" },
        "year": { "type": "integer" },
        "stats": {
          "type": "object",
          "properties": {
            "newUsers": { "type": "integer" },
            "newDrivers": { "type": "integer" },
            "totalOrders": { "type": "integer" },
            "deliveredOrders": { "type": "integer" },
            "cancelledOrders": { "type": "integer" },
            "totalRevenue": { "type": "number" },
            "disputesCount": { "type": "integer" }
          }
        },
        "advice": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "year", "stats", "advice", "createdAt"]
    },
    "PendingVerification": {
      "title": "PendingVerification",
      "description": "Temporary storage for user registration data awaiting verification.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "userData": {
          "type": "object",
          "properties": {
            "nom": { "type": "string" },
            "role": { "type": "string" },
            "password": { "type": "string" }
          }
        }
      },
      "required": ["code", "expiresAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "pending_verifications/{verificationId}": {
      "schema": "PendingVerification",
      "description": "Registration attempts awaiting code verification"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Delivery orders"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Delivery reviews"
    },
    "admin_notifications/{notifId}": {
      "schema": "AdminNotification",
      "description": "Admin notifications"
    },
    "admin_logs/{logId}": {
      "schema": "AdminLog",
      "description": "Logs of admin actions"
    },
    "admin_reports/{reportId}": {
      "schema": "AdminReport",
      "description": "Monthly admin reports"
    },
    "settings/{settingId}": {
      "schema": {
        "type": "object",
        "properties": {
          "fixedFee": { "type": "number" }
        }
      },
      "description": "App settings"
    }
  }
}
